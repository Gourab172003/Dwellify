<% layout("layouts/boilerplate") %>
<br>
<div class="heading" style="color: red;
    display: flex;
    align-items: center;
    gap: 8px;           
">
  <i class="fa-regular fa-compass" style="font-size: 3rem !important"></i>
<h3>Dwellify</h3>
</div>


<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 row-cols-es-1">
  <% for(let listing of allListings) { %>
    <div class="col-md-4 mb-3">
      <a href="/listing/<%= listing._id %>" class="listing-link">
        <div class="card">
          <img src="<%= listing.image %>" class="card-img-top" alt="LISTING_IMAGE" style="height:20rem">
          <div class="card-body" style="text-decoration: none;">
            <p class="card-text" style="text-decoration: none;">
            <b>  <%= listing.title %></b> <br>
              ₹ <%= listing.price.toLocaleString("en-IN") %> /month
            </p>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>