<% layout("layouts/boilerplate") %>
<div class="editrows">
<div class="col-7 offset-3">
<body>
    <form method="POST" action="/listings/edit/update/<%=id%>?_method=PUT">
      <br>
      <div class="editinfo">
        <div class="userID"><h3> User Id: <h3></div>
          <div class="id"><h3><%=id%></h3></div> 
      </div>
    
    

    <div>
    <label for="exampleFormControlInput1" class="form-label"></label>
    <h4 style="font-size: 1.3rem;"> Title: <input name="Listing[newTitle]"textarea="Enter Title" type="text" class="form-control"> </h4>
    </div>

    <div>
      <label for="exampleFormControlInput1" class="form-label"></label>
     <h4 style="font-size: 1.3rem;"> Description: <input name="Listing[newDescription]" placeholder="Enter Description" type="text" class="form-control"></h4>
     </div>

     <div>
      <label for="exampleFormControlInput1" class="form-label"></label>
      <h4 style="font-size: 1.3rem;"> Image: <input name="Listing[newImage]"textarea="Enter Image URL" type="text" class="form-control"></h4>
      </div>
      
      <div>
        <label for="exampleFormControlInput1" class="form-label"></label>
       <h4 style="font-size: 1.3rem;"> Price: <input name="Listing[newPrice]" textarea="Enter new Price" type="number" class="form-control"></h4>
       </div>
       
       <div>
         <label for="exampleFormControlInput1" class="form-label"></label>
         <h4 style="font-size: 1.3rem;"> Location: <input name="Listing[newLocation]"textarea="Enter new Location" type="text" class="form-control"></h4>
        </div>

        <div>
           <label for="exampleFormControlInput1" class="form-label"></label>
           <h4 style="font-size: 1.3rem;"> Country: <input name="Listing[newCountry]" textarea="Enter new Country" type="text" class="form-control"></h4>
        </div>
        <br>
        <div class="ediBtn">
           <button class="editbtn"> Submit </button>
           </div>
           <br>
            </form>
</body>
</div>
</div>
</html>